<div class="contextual">
  <%= link_to 'Plugin settings', { controller: 'settings', action: 'plugin', id: 'redmine_slow_query_logger' }, class: 'icon icon-settings' %>
  <%= link_to 'Clear journal', slow_query_logger_entries_path, method: :delete, data: { confirm: 'Clear all slow query journal entries?' }, class: 'icon icon-del' %>
</div>

<h2>Slow query log</h2>

<form action="<%= url_for(controller: 'slow_query_logger_entries', action: 'index') %>" method="get">
  <fieldset>
    <legend>Filters</legend>
    <p>
      <label>Type</label>
      <%= select_tag :event_type, options_for_select([['All', ''], ['SQL', 'sql'], ['Request', 'request']], @event_type) %>

      <label>Login</label>
      <%= text_field_tag :login, @login, size: 20 %>

      <label>IP</label>
      <%= text_field_tag :ip, @ip, size: 16 %>

      <label>Request ID</label>
      <%= text_field_tag :request_id, @request_id, size: 24 %>
    </p>

    <p>
      <label>From</label>
      <%= text_field_tag :from, @from, size: 18, placeholder: 'YYYY-MM-DD HH:MM' %>

      <label>To</label>
      <%= text_field_tag :to, @to, size: 18, placeholder: 'YYYY-MM-DD HH:MM' %>

      <label>Min duration, ms</label>
      <%= number_field_tag :min_duration_ms, @min_duration_ms, min: 0, step: 100 %>

      <label>Limit</label>
      <%= number_field_tag :limit, params.fetch(:limit, 100), min: 10, max: 1000, step: 10 %>

      <%= submit_tag 'Apply', name: nil %>
      <%= link_to 'Reset', { controller: 'slow_query_logger_entries', action: 'index' } %>
    </p>
  </fieldset>
</form>

<p><%= @entry_count %> matching entries. Showing latest <%= @entries.size %>.</p>

<table class="list">
  <thead>
    <tr>
      <th>Time</th>
      <th>Type</th>
      <th>Duration</th>
      <th>User</th>
      <th>IP</th>
      <th>Request</th>
      <th>SQL / Summary</th>
    </tr>
  </thead>
  <tbody>
    <% @entries.each do |entry| %>
      <tr class="<%= cycle('odd', 'even') %>">
        <td><%= format_time(entry.created_at) %></td>
        <td><%= entry.event_type %></td>
        <td>
          <strong><%= entry.duration_ms.round(1) %> ms</strong>
          <% if entry.threshold_ms.present? %>
            <br><span class="small">threshold <%= entry.threshold_ms %> ms</span>
          <% end %>
        </td>
        <td>
          <% if entry.user_id.present? %>
            #<%= entry.user_id %>
          <% end %>
          <%= h(entry.login) %>
        </td>
        <td><%= h(entry.ip) %></td>
        <td>
          <%= h([entry.http_method, entry.status].compact.join(' ')) %>
          <% if entry.request_id.present? %>
            <br>
            <%= link_to h(entry.request_id), { controller: 'slow_query_logger_entries', action: 'index', request_id: entry.request_id }, class: 'small' %>
          <% end %>
          <% if entry.path.present? %>
            <br><code><%= h(entry.path) %></code>
          <% end %>
        </td>
        <td>
          <% if entry.event_type == 'request' %>
            SQL: <%= entry.sql_count || 0 %>,
            slow SQL: <%= entry.slow_sql_count || 0 %>,
            SQL time: <%= (entry.sql_duration_ms || 0).round(1) %> ms
          <% else %>
            <% if entry.sql_name.present? %>
              <strong><%= h(entry.sql_name) %></strong><br>
            <% end %>
            <% if entry.respond_to?(:sql_truncated) && entry.sql_truncated? %>
              <span class="small">SQL was truncated before storing.</span>
            <% end %>
            <pre style="white-space: pre-wrap; max-width: 900px;"><%= h(entry.sql) %></pre>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
